# Python / build artefacts
/__pycache__/
**/__pycache__/
/.pytest_cache/
pytest-cache-files-*/
/pip/
/venv/

# IDE
/.idea/

# Local ComfyUI runtime caches (HF model snapshots, pip tmp, test fixtures)
/.cache/
**/.cache/
/.test_models/
/.test_input/

# AI assistant scratch (Claude Code / Codex)
/.claude/
/.codex_tmp/

# Local-only AI memory & developer infrastructure — kept in the dev
# location alongside the pack, but not published to GitHub or the Comfy
# registry. Keeps the public repo focused on shippable runtime code and
# stops the registry security scanner from inspecting test / tooling
# code that would otherwise trip false-positives.
/project_memory/
/tests/
/tools/

# Local-only AI-assistant instructions and engineering plans
CLAUDE.md
AGENTS.md
MODERNIZATION_PLAN.md
comfyui-pack-testing-guide.md

# Internal contributor docs — kept in dev only; doc/screenshots/ stays
# because README.md links to it.
/doc/AGENTS.md
/doc/TS_DEPENDENCY_POLICY.md
/doc/migration.md
/doc/generate_readme_ru.py
